# Tuned Yota — environment variables (set these in Netlify → Site settings → Environment)

# Email (existing — lead routing + booking confirmations)
RESEND_API_KEY=

# Event dates: the published Google Sheet ID (same sheet the event map reads).
# The booking functions read each city's event date from it.
# Booking only "comes alive" once this is set with at least one active, dated city.
EVENTS_SHEET_ID=

# Airtable (bookings + Priority Event List)
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_BOOKINGS_TABLE=Bookings
AIRTABLE_PRIORITY_TABLE=Priority List
